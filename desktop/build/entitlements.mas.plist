<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Mac App Store builds MUST run under App Sandbox. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Electron/Chromium requirements under sandbox -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Chromium's Mach IPC + Safe Storage need an app group scoped to the
         team id. electron-builder substitutes nothing here — keep in sync
         with the Apple Developer Team ID used for signing. -->
    <key>com.apple.security.application-groups</key>
    <array>
      <string>8TJHY75AV5.site.lexio.app</string>
    </array>

    <!-- Outgoing HTTPS to lexio.site (define/auth/billing APIs) -->
    <key>com.apple.security.network.client</key>
    <true/>
  </dict>
</plist>
