<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Electron requires unsigned executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Required for certain native node modules (like uiohook-napi) if they aren't fully signed by the same team -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required for the JXA / AppleScript context fallback reading AX values via System Events -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
  </dict>
</plist>
