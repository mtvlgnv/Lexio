{
  "name": "lexio-desktop",
  "version": "1.5.0",
  "description": "Lexio — floating contextual dictionary",
  "main": "main-overlay.js",
  "scripts": {
    "start": "electron .",
    "start-overlay": "electron main-overlay.js",
    "create-icon": "node_modules/.bin/electron create-icon.js",
    "build-icons": "bash scripts/build-icons.sh",
    "build-ocr": "bash native/build-ocr.sh",
    "dist": "npm run build-icons && npm run build-ocr && electron-builder --mac --arm64",
    "dist:mas": "npm run build-icons && npm run build-ocr && electron-builder --mac mas --arm64 -c.appId=site.lexio.app -c.productName=Lexio",
    "dist:mas-dev": "npm run build-icons && npm run build-ocr && electron-builder --mac mas-dev --arm64 -c.appId=site.lexio.app -c.productName=Lexio"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^25.0.0"
  },
  "overrides": {
    "node-abi": "latest"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.4"
  },
  "build": {
    "appId": "site.lexio.glance",
    "productName": "Lexio Glance",
    "afterSign": "scripts/notarize.js",
    "asarUnpack": [
      "lib/ax-reader.py",
      "bin/lexio-ocr"
    ],
    "files": [
      "main-overlay.js",
      "store.js",
      "lib/**/*",
      "bin/**/*",
      "pill.html",
      "onboarding.html",
      "hub.html",
      "home.html",
      "compact.html",
      "tokens.css",
      "preload-overlay.js",
      "preload-onboarding.js",
      "preload-hub.js",
      "node_modules/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Lexio",
        "schemes": [
          "lexio"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "mtvlgnv",
        "repo": "Lexio"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Lexio Glance reads text near your cursor to provide contextual word definitions, including subtitles and text that can't be selected."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "mas": {
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/embedded.provisionprofile",
      "hardenedRuntime": false,
      "extendInfo": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSScreenCaptureUsageDescription": "Lexio reads text near your cursor to provide contextual word definitions, including subtitles and text that can't be selected."
      }
    },
    "masDev": {
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/dev.provisionprofile",
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "Lexio Glance",
      "artifactName": "Lexio-Glance-${version}-arm64.dmg",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "posthog-node": "^4.18.0"
  }
}
