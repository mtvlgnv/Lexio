{
  "name": "lexio-desktop",
  "version": "1.1.5",
  "description": "Lexio — floating contextual dictionary",
  "main": "main-overlay.js",
  "scripts": {
    "start": "electron .",
    "start-app": "electron main-app.js",
    "start-overlay": "electron main-overlay.js",
    "create-icon": "node_modules/.bin/electron create-icon.js",
    "build-icons": "bash scripts/build-icons.sh",
    "dist": "npm run create-icon && npm run build-icons && electron-builder --mac --arm64",
    "dist-app": "npm run create-icon && npm run build-icons && electron-builder --mac --arm64 --config electron-builder-app.json"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^25.0.0"
  },
  "overrides": {
    "node-abi": "latest"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.4"
  },
  "build": {
    "appId": "site.lexio.glance",
    "productName": "Lexio Glance",
    "afterSign": "scripts/notarize.js",
    "asarUnpack": [
      "lib/ax-reader.py"
    ],
    "files": [
      "main-overlay.js",
      "store.js",
      "lib/**/*",
      "pill.html",
      "onboarding.html",
      "hub.html",
      "compact.html",
      "tokens.css",
      "preload-overlay.js",
      "preload-onboarding.js",
      "preload-hub.js",
      "node_modules/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Lexio",
        "schemes": [
          "lexio"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Lexio Glance",
      "artifactName": "Lexio-Glance-${version}-arm64.dmg",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
