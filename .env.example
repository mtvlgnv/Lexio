# ── Required (core) ──────────────────────────────────────────────────────────
# JWT signing key. Generate with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=replace-me-with-a-long-random-string

# AI providers — at least one is required.
# Fast mode (GPT-4o Mini) + OCR fallback
OPENAI_API_KEY=sk-...
# Balanced mode (Gemini 2.5 Flash) + primary OCR
GOOGLE_API_KEY=...
# Deep mode (Claude Sonnet 4.5)
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (required for the Pro tier) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly recurring price (multi-currency). Required.
STRIPE_PRICE_ID=price_...
# Yearly recurring price (multi-currency). Optional but recommended — when
# unset, the landing page hides the yearly toggle automatically.
STRIPE_PRICE_ID_YEARLY=price_...
# Suffix appended to the account-level statement descriptor on Stripe
# invoices (≤ 22 chars, alphanumeric/spaces only). Also set the account-
# level descriptor in Stripe Dashboard → Settings → Public details.
STRIPE_STATEMENT_DESCRIPTOR_SUFFIX=PRO
SITE_URL=https://lexio.site

# ── OAuth sign-in (optional) ─────────────────────────────────────────────────
# Leave blank to disable the corresponding sign-in button.
GOOGLE_CLIENT_ID=
APPLE_SERVICES_ID=

# ── Email / password reset & verification (optional) ─────────────────────────
# Any standard SMTP relay (Mailgun, Postmark, SES…). All four must be set
# together to enable password-reset emails AND the email verification
# step required before checkout. Without SMTP, new password registrations
# are auto-verified (graceful degradation for dev/preview boxes).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ── Admin (optional) ─────────────────────────────────────────────────────────
# Bearer token used to access admin-only endpoints.
ADMIN_KEY=
