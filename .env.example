# ── Required (core) ──────────────────────────────────────────────────────────
# JWT signing key. Generate with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=replace-me-with-a-long-random-string

# AI providers — at least one is required.
# Fast mode (GPT-4o Mini) + OCR fallback
OPENAI_API_KEY=sk-...
# Balanced mode (Gemini 2.5 Flash) + primary OCR
GOOGLE_API_KEY=...
# Deep mode (Claude Sonnet 4.5)
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (required for the Pro tier) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
SITE_URL=https://lexio.site

# ── OAuth sign-in (optional) ─────────────────────────────────────────────────
# Leave blank to disable the corresponding sign-in button.
GOOGLE_CLIENT_ID=
APPLE_SERVICES_ID=

# ── Email / password reset (optional) ────────────────────────────────────────
# Any standard SMTP relay (Mailgun, Postmark, SES…). All four must be set
# together for password-reset emails to send.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ── Admin (optional) ─────────────────────────────────────────────────────────
# Bearer token used to access admin-only endpoints.
ADMIN_KEY=
